# 云端 WebSocket 服务地址
SERVER_URL=ws://localhost:8000/ws/client

# 认证 Token
AGENT_TOKEN=

# 客户端唯一标识符
CLIENT_ID=default

# Claude Code 模型 (sonnet/opus/haiku)
CLAUDE_MODEL=sonnet

# 最大迭代次数
CLAUDE_MAX_TURNS=10

# 执行超时（秒）
CLAUDE_TIMEOUT=300

# 权限模式 (default/acceptEdits/bypassPermissions)
CLAUDE_PERMISSION_MODE=default

# 自动放行的工具白名单（逗号分隔）
CLAUDE_AUTO_APPROVE_TOOLS=Read,Glob,Grep

# 心跳间隔（秒）
HEARTBEAT_INTERVAL=30

# 重连延迟（秒）
RECONNECT_DELAY=5

# 最大重连次数（0=无限）
MAX_RECONNECT_ATTEMPTS=0

# 日志级别
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE=logs/agent.log
