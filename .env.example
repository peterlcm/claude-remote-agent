# 云端WebSocket服务地址
SERVER_URL=ws://localhost:8765

# 客户端认证Token
AGENT_TOKEN=your-secret-agent-token

# Claude配置
CLAUDE_MODEL=sonnet
CLAUDE_MAX_TURNS=10
CLAUDE_TIMEOUT=300

# Claude 工具权限策略
# - default: 通过 Permission MCP 让前端逐次确认（推荐）
# - acceptEdits: 自动接受文件编辑，其他工具仍走确认
# - bypassPermissions: 完全跳过权限（仅本地调试用）
CLAUDE_PERMISSION_MODE=default

# 这些工具会在 --allowedTools 中预先放行，绕过确认弹窗
CLAUDE_AUTO_APPROVE_TOOLS=Read,Glob,Grep

# 客户端配置
CLIENT_ID=agent-001
HEARTBEAT_INTERVAL=30
RECONNECT_DELAY=5
MAX_RECONNECT_ATTEMPTS=0

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/agent.log
