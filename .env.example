# 云端WebSocket服务地址
SERVER_URL=ws://localhost:8765

# 客户端认证Token
AGENT_TOKEN=your-secret-agent-token

# Claude配置
CLAUDE_MODEL=sonnet
CLAUDE_MAX_TURNS=10
CLAUDE_EFFORT=medium
CLAUDE_TIMEOUT=300

# 客户端配置
CLIENT_ID=agent-001
HEARTBEAT_INTERVAL=30
RECONNECT_DELAY=5
MAX_RECONNECT_ATTEMPTS=0

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/agent.log
